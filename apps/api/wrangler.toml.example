name = "r2shelf-api"
main = "src/index.ts"
compatibility_date = "2024-01-01"
compatibility_flags = ["nodejs_compat"]

[[d1_databases]]
binding = "DB"
database_name = "r2shelf-db"
database_id = ""

[[r2_buckets]]
binding = "FILES"
bucket_name = "r2shelf-files"

[[kv_namespaces]]
binding = "KV"
id = ""

[vars]
ENVIRONMENT = "development"
JWT_SECRET = "your-jwt-secret-change-in-production"
